{
  "name": "eslint-plugin-jsx-a11y-x",
  "version": "0.1.1",
  "type": "commonjs",
  "description": "An ESLint plugin to apply various a11y rules to JSX templates",
  "repository": "git+https://github.com/es-tooling/eslint-plugin-jsx-a11y-x.git",
  "homepage": "https://github.com/es-tooling/eslint-plugin-jsx-a11y-x#readme",
  "author": "ES Tooling authors (https://github.com/es-tooling)",
  "maintainers": [
    "JounQin <admin@1stg.me> (https://www.1stG.me)"
  ],
  "license": "MIT",
  "engines": {
    "node": "^18.18.0 || ^20.9.0 || >=21.1.0"
  },
  "main": "lib/index.js",
  "files": [
    "lib"
  ],
  "keywords": [
    "jsx",
    "a11y",
    "eslint",
    "eslint-plugin",
    "eslint-plugin-jsx-a11y"
  ],
  "scripts": {
    "build": "premove lib && babel src --out-dir lib --copy-files",
    "create": "node ./scripts/create-rule",
    "format": "prettier --write .",
    "generate-list-of-rules": "eslint-doc-generator --rule-doc-title-format prefix-name --rule-doc-section-options false --config-emoji recommended,☑️ --ignore-config flat/recommended --ignore-config flat/strict",
    "lint": "npm run lint:js && npm run lint:docs",
    "lint:docs": "npm run generate-list-of-rules --check",
    "lint:js": "eslint",
    "lint:js:fix": "npm run lint:js --fix",
    "pregenerate-list-of-rules": "npm run build",
    "prepublishOnly": "npm run lint && npm run tests-only",
    "release": "npm run build && changeset publish",
    "test": "npm run tests-only",
    "test-example:flat-cjs": "cd examples/flat-cjs && npm i && npm run lint",
    "test-example:flat-esm": "cd examples/flat-esm && npm i && npm run lint",
    "test-example:legacy": "cd examples/legacy && npm i && npm run lint",
    "test:examples": "npm run build && npm run test-example:legacy && npm run test-example:flat-esm && npm run test-example:flat-cjs",
    "tests-only": "jest --coverage"
  },
  "peerDependencies": {
    "eslint": "^8.57.0 || ^9.0.0"
  },
  "dependencies": {
    "aria-query": "^5.3.2",
    "ast-types-flow": "^0.0.8",
    "axe-core": "^4.10.2",
    "axobject-query": "^4.1.0",
    "damerau-levenshtein": "^1.0.8",
    "emoji-regex": "^9.2.2",
    "jsx-ast-utils-x": "^0.1.0",
    "language-tags": "^1.0.9",
    "minimatch": "^3.1.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.25.9",
    "@babel/core": "^7.26.0",
    "@babel/eslint-parser": "^7.25.9",
    "@babel/plugin-transform-flow-strip-types": "^7.25.9",
    "@babel/preset-env": "^7.27.2",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.4",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.26.0",
    "babel-plugin-add-module-exports": "^1.0.4",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-doc-generator": "^1.7.1",
    "eslint-import-resolver-typescript": "^4.4.1",
    "eslint-plugin-eslint-plugin": "^6.4.0",
    "eslint-plugin-import-x": "^4.13.3",
    "estraverse": "^5.3.0",
    "jscodeshift": "^17.3.0",
    "minimist": "^1.2.8",
    "npm-run-all2": "^8.0.2",
    "premove": "^4.0.0",
    "prettier": "^3.5.3",
    "semver": "^6.3.1"
  }
}
